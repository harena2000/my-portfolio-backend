{
  "name": "my-portfolio-backend",
  "version": "1.0.0",
  "description": "Express REST API for portfolio admin backoffice",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
